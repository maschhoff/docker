<?xml version="1.0"?>
<Container version="2">
  <Name>imapsync-web</Name>
  <Repository>knex666/imapsyncweb:latest</Repository>
  <Registry>https://hub.docker.com/r/knex666/imapsyncweb</Registry>
  <Network>bridge</Network>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/maschhoff/imapsyncweb/issues</Support>
  <Project>https://github.com/maschhoff/imapsyncweb</Project>
  <Overview>A modern, dark-themed web interface for imapsync — the IMAP migration and backup tool.&#xA;&#xA;Features:&#xA;&#xA;- Side-by-side server config for source and destination IMAP accounts&#xA;- Toggle switches for SSL/TLS, dry run, delete, subscribe and more&#xA;- Live log streaming with color-coded output (transfers, errors, warnings, folders)&#xA;- Real-time stats: messages transferred, skipped, bytes, errors&#xA;- Command preview showing the exact imapsync command that will run&#xA;- Job history with status tracking&#xA;- Stop running jobs with a click</Overview>
  <Category>Tools:Utilities</Category>
  <WebUI>http://[IP]:[PORT:5000]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/maschhoff/imapsyncweb/main/imapsync-web.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/maschhoff/imapsyncweb/main/icon.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DonateText>Buy me a Pizza 🍕</DonateText>
  <DonateLink>https://www.buymeacoffee.com/maschhoff</DonateLink>
  <Config Name="WebUI Port" Target="5000" Default="5000" Mode="tcp" Description="Port for the imapsync web interface." Type="Port" Display="always" Required="true" Mask="false">5000</Config>
</Container>
